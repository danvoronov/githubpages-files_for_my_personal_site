---
layout: updates-layout.njk
pagination:
  data: updates
  size: 120
  alias: posts
permalink: "{% if pagination.pageNumber == 0 %}updates/index.html{% else %}updates/page/{{ pagination.pageNumber + 1 }}/index.html{% endif %}"
eleventyComputed:
  title: "{% if pagination.pageNumber == 0 %}Updates{% else %}Updates - Page {{ pagination.pageNumber + 1 }}{% endif %}"
  description: "{{ site.updatesDescription }}"
---
<div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
  <a href="/" data-esc-back style="color: #DD4723"><b>&lt; back (ESC)</b></a>
  {% if pagination.href.previous or pagination.href.next %}
  <span>
    {% if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}" style="color: #DD4723">&lt; Newer</a>
    {% endif %}
    {% if pagination.href.previous and pagination.href.next %}
    <span style="color:#666"> | </span>
    {% endif %}
    {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}" style="color: #DD4723">Older &gt;</a>
    {% endif %}
    <span style="color:#666"> | Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
  </span>
  {% endif %}
</div>

<p style="color:black">{{ updates | length }} posts</p>

 · <a href="/updates/search/" style="color: #DD4723">Search archive</a> · <a href="/updates/feed.xml" style="color: #DD4723">RSS feed</a>

<style>
  #content ul.updates-index-list {
    margin: 0;
    padding: 0;
    list-style: none;
    color: black;
    line-height: 1.8;
  }

  #content ul.updates-index-list li.updates-index-item {
    margin-bottom: 8px;
    padding: 0;
    list-style: none;
    margin-left: 12px;
  }

  #content ul.updates-index-list li.updates-index-item.updates-index-item--new-month {
    margin-top: 6px;
  }

  #content ul.updates-index-list li.updates-index-year {
    margin: 23px 0 12px;
    padding: 0;
    list-style: none;
    color: black;
    font-size: 1.1rem;
    font-weight: 700;
  }

  #content ul.updates-index-list li.updates-index-year:first-child {
    margin-top: 0;
  }

  .updates-index-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.45rem;
  }

  .updates-index-number,
  .updates-index-date {
    color: #666;
  }

  .updates-index-date {
    display: inline-block;
    padding: 1px 6px;
    color: #fff;
    background: #2f4a36;
    border: 1px solid #1f3325;
    border-radius: 0;
    line-height: 1.3;
  }

  .updates-index-separator {
    display: inline-block;
    width: 0.45rem;
    color: transparent;
    user-select: none;
  }

</style>

{% set totalPosts = updates | length %}
{% set pageStart = totalPosts - (pagination.pageNumber * pagination.size) %}
<ul class="updates-index-list">
  {% for post in posts %}
  {% set globalIndex = pageStart - loop.index0 %}
  {% set postYear = post.date.slice(0, 4) %}
  {% set postMonth = post.date.slice(0, 7) %}
  {% set postMonthDay = post.date.slice(5, 10) %}
  {% set prevPost = posts[loop.index0 - 1] if loop.index0 > 0 else null %}
  {% set prevYear = prevPost.date.slice(0, 4) if prevPost else null %}
  {% set prevMonth = prevPost.date.slice(0, 7) if prevPost else null %}
  {% if postYear != prevYear %}
  <li class="updates-index-year">{{ postYear }}</li>
  {% endif %}
  <li class="updates-index-item{% if prevPost and postMonth != prevMonth %} updates-index-item--new-month{% endif %}">
    <div class="updates-index-row">
      <span class="updates-index-number">{{ globalIndex }}</span>
      <span class="updates-index-separator" aria-hidden="true">&nbsp;</span>
      <time datetime="{{ post.date }}" class="updates-index-date">{{ postMonthDay }}</time>
      <span class="updates-index-separator" aria-hidden="true">&nbsp;</span>
      <a href="{{ post.url }}">{{ post.title }}</a>
    </div>
  </li>
  {% endfor %}
</ul>

{% if pagination.href.previous or pagination.href.next %}
<div style="padding-top:23px; text-align:center;">
  {% if pagination.href.previous %}
  <a href="{{ pagination.href.previous }}" style="color: #DD4723">&lt; Newer</a>
  {% endif %}
  {% if pagination.href.previous and pagination.href.next %}
  <span style="color:#666"> | </span>
  {% endif %}
  {% if pagination.href.next %}
  <a href="{{ pagination.href.next }}" style="color: #DD4723">Older &gt;</a>
  {% endif %}
  <span style="color:#666"> | Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
</div>
{% endif %}
